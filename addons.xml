<?xml version="1.0" encoding="UTF-8"?>
<addons>
  <addon id="repository.dotjustin" name="dotJustin's Kodi Repository" version="1.0.0" provider-name="dotJustin">
    <requires>
      <import addon="xbmc.addon" version="12.0.0" />
    </requires>
    <extension point="xbmc.addon.repository" name="dotJustin's Kodi Repository">
      <info compressed="false">https://dot-justin.github.io/kodi-repo/addons.xml</info>
      <checksum>https://dot-justin.github.io/kodi-repo/addons.xml.md5</checksum>
      <datadir zip="true">https://dot-justin.github.io/kodi-repo/</datadir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">dotJustin's Kodi Repository</summary>
      <description lang="en_GB">Kodi addons by dotJustin. Includes Bouncer (rating-based playback control) and future addons.</description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="service.bouncer" name="Bouncer" version="1.0.0" provider-name="dotJustin">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.service" library="service.py" start="login" />
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Rating-based playback control for Kodi</summary>
      <platform>all</platform>
    </extension>
  </addon>
</addons>
